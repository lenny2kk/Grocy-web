rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Reguły dla kolekcji użytkowników (/users)
    match /users/{userId} {
      // Każdy zalogowany użytkownik może odczytać profil innego użytkownika
      // (wymagane do wyszukiwania i listowania członków rodziny)
      allow read: if request.auth != null;
      
      // Zalogowany użytkownik może tworzyć i edytować tylko swój własny profil
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Reguły dla prywatnej listy zakupów każdego użytkownika
      match /private_shopping_list/{itemId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Reguły dla kolekcji rodzin (/families)
    match /families/{familyId} {
      // Pozwól na odczyt i zapis w obrębie rodziny dowolnemu zalogowanemu użytkownikowi.
      // W wersji produkcyjnej można dodatkowo ograniczyć to do członków grupy,
      // sprawdzając dokument użytkownika:
      // allow read, write: if request.auth != null && 
      //   get(/databases/$(database)/documents/users/$(request.auth.uid)).data.currentFamilyId == familyId;
      allow read, write: if request.auth != null;

      match /{document=**} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
